{\n  \"name\": \"frontend\",\n  \"private\": true,\n  \"version\": \"0.0.0\",\n  \"type\": \"module\",\n  \"scripts\": {\n    \"dev\": \"vite\",\n    \"build\": \"tsc -b && vite build\",\n    \"build:preview\": \"vite build\",\n    \"lint\": \"eslint --format unix .\",\n    \"preview\": \"vite preview\",\n    \"test\": \"vitest\",\n    \"coverage\": \"vitest run --coverage\",\n    \"test:jsdom\": \"vitest --environment=jsdom\",\n    \"type-check\": \"tsc -p tsconfig.app.json --noEmit\",\n    \"smoke:frontend\": \"npm run build:preview && playwright install chromium && playwright test --config playwright.config.ts tests/smoke.spec.ts\",\n    \"prepare\": \"node -e \\\"if(require('fs').existsSync('.git')){require('husky').install();}\\\"\",\n    \"deploy:aws\": \"powershell -ExecutionPolicy Bypass -File scripts/deploy-to-aws.ps1 -BucketName $env:S3_BUCKET -DistributionId $env:CLOUDFRONT_DISTRIBUTION_ID\",\n    \"deploy:aws:linux\": \"bash scripts/deploy-to-aws.sh -b $S3_BUCKET ${CLOUDFRONT_DISTRIBUTION_ID:+-d $CLOUDFRONT_DISTRIBUTION_ID}\"\n  },\n  \"dependencies\": {\n    \"@radix-ui/react-collapsible\": \"^1.1.12\",\n    \"@tanstack/react-virtual\": \"^3.13.18\",\n    \"i18next\": \"^25.6.3\",\n    \"lucide-react\": \"^0.562.0\",\n    \"react\": \"^18.3.1\",\n    \"react-dom\": \"^18.3.1\",\n    \"react-helmet-async\": \"^2.0.5\",\n    \"react-i18next\": \"^15.7.4\",\n    \"react-router-dom\": \"^7.12.1\",\n    \"react-toastify\": \"^10.0.0\",\n    \"react-window\": \"^1.8.11\",\n    \"recharts\": \"^3.6.0\",\n    \"sharp\": \"^0.34.5\",\n    \"vite-plugin-ssr\": \"^0.4.142\"\n  },\n  \"devDependencies\": {\n    \"@eslint/js\": \"^9.30.1\",\n    \"@playwright/test\": \"^1.55.1\",\n    \"@tailwindcss/oxide\": \"^4.1.12\",\n    \"@tailwindcss/postcss\": \"^4.1.12\",\n    \"@testing-library/jest-dom\": \"^6.6.4\",\n    \"@testing-library/react\": \"^16.3.0\",\n    \"@testing-library/user-event\": \"^14.6.1\",\n    \"@types/jest-axe\": \"^3.5.9\",\n    \"@types/jsdom\": \"^21.1.7\",\n    \"@types/react\": \"^18.3.23\",\n    \"@types/react-dom\": \"^18.3.7\",\n    \"@vitejs/plugin-react\": \"^4.6.0\",\n    \"@vitest/coverage-v8\": \"^3.2.4\",\n    \"autoprefixer\": \"^10.4.21\",\n    \"eslint\": \"^9.30.1\",\n    \"eslint-config-google\": \"^0.14.0\",\n    \"eslint-config-prettier\": \"^10.1.8\",\n    \"eslint-formatter-unix\": \"^8.40.0\",\n    \"eslint-plugin-react-hooks\": \"^5.2.0\",\n    \"eslint-plugin-react-refresh\": \"^0.4.20\",\n    \"globals\": \"^16.3.0\",\n    \"husky\": \"^9.1.7\",\n    \"jest-axe\": \"^10.0.0\",\n    \"jsdom\": \"^26.1.0\",\n    \"lightningcss\": \"^1.30.1\",\n    \"lint-staged\": \"^16.1.5\",\n    \"postcss\": \"^8.5.6\",\n    \"prettier\": \"^3.6.2\",\n    \"tailwindcss\": \"^4.1.12\",\n    \"typescript\": \"~5.8.3\",\n    \"typescript-eslint\": \"^8.35.1\",\n    \"vite\": \"^7.0.4\",\n    \"vite-imagetools\": \"^8.0.0\",\n    \"vitest\": \"^3.2.4\",\n    \"zod\": \"^4.1.5\"\n  },\n  \"lint-staged\": {\n    \"*.{js,jsx,ts,tsx}\": [\n      \"eslint --max-warnings=0\",\n      \"prettier --check\"\n    ],\n    \"*.{json,css,md}\": [\n      \"prettier --check\"\n    ]\n  }\n}\n