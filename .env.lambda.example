# Copy to .env.lambda to customise the local Lambda Docker harness.
APP_ENV=local
DISABLE_AUTH=true
GOOGLE_AUTH_ENABLED=false
JWT_SECRET=local-lambda-dev-secret
GOOGLE_CLIENT_ID=local-lambda-client
DATA_ROOT=/var/task/data
DATA_BUCKET=local-lambda-data
METADATA_BUCKET=local-lambda-metadata
METADATA_PREFIX=instruments
QUOTES_TABLE=QuotesLocal
REPORT_TEMPLATES_TABLE=ReportTemplatesLocal
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_SESSION_TOKEN=dummy
AWS_DEFAULT_REGION=us-east-1
APP_REGION=us-east-1
AWS_ENDPOINT_URL_DYNAMODB=http://dynamodb-local:8000
ALPHA_VANTAGE_KEY=demo
OPENAI_API_KEY=
LAMBDA_HANDLER=backend.lambda_api.handler.lambda_handler
LAMBDA_HOST_PORT=9000
DYNAMODB_HOST_PORT=8001
MAILHOG_SMTP_HOST_PORT=1025
MAILHOG_UI_HOST_PORT=8025
