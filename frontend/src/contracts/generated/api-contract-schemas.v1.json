{
  "version": "v1",
  "endpoints": {
    "config": {
      "path": "/config",
      "schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "app_env": {
            "type": "string"
          },
          "theme": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "tabs": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "relative_view_enabled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "google_auth_enabled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "google_client_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "disable_auth": {
            "type": "boolean"
          },
          "allowed_emails": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "local_login_email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "disabled_tabs": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "app_env",
          "theme",
          "tabs",
          "relative_view_enabled",
          "google_auth_enabled",
          "google_client_id",
          "disable_auth",
          "allowed_emails",
          "local_login_email"
        ],
        "additionalProperties": {}
      }
    },
    "owners": {
      "path": "/owners",
      "schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "full_name": {
              "type": "string"
            },
            "accounts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "email": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "has_transactions_artifact": {
              "type": "boolean"
            }
          },
          "required": [
            "owner",
            "full_name",
            "accounts",
            "has_transactions_artifact"
          ],
          "additionalProperties": false
        }
      }
    },
    "groups": {
      "path": "/groups",
      "schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "slug": {
