{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:preview": "vite build",
    "lint": "eslint --format unix .",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:jsdom": "vitest --environment=jsdom",
    "type-check": "tsc -b --noEmit",
    "smoke:frontend": "npm run build:preview && playwright install chromium && playwright test --config playwright.config.ts tests/smoke.spec.ts tests/cognito-auth-flow.spec.ts",
    "prepare": "node -e \"if(require('fs').existsSync('.git')){require('husky').install();}\"",
    "deploy:aws": "powershell -ExecutionPolicy Bypass -File scripts/deploy-to-aws.ps1 -BucketName $env:S3_BUCKET -DistributionId $env:CLOUDFRONT_DISTRIBUTION_ID",
    "deploy:aws:linux": "bash scripts/deploy-to-aws.sh -b $S3_BUCKET ${CLOUDFRONT_DISTRIBUTION_ID:+-d $CLOUDFRONT_DISTRIBUTION_ID}",
    "smoke:codex:poc": "npm run build:preview && playwright install chromium && playwright test --config playwright.config.ts --grep \"bootstrap to portfolio happy path\" tests/smoke.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@tanstack/react-virtual": "^3.14.2",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "react-toastify": "^11.1.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/oxide": "^4.3.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.0",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --check"
    ],
    "*.{json,css,md}": [
      "prettier --check"
    ]
  },
  "overrides": {
    "@babel/core": "^7.29.6"
  }
}
